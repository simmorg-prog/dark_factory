<mxGraphModel><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="All three execute the specification they are given with fidelity." style="text;html=1;strokeColor=none;fillColor=#1F3864;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="30" y="20" width="740" height="40" as="geometry"/></mxCell><mxCell id="3" value="DETERMINISTIC SYSTEMS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2D3748;strokeColor=#D4A017;fontSize=13;fontStyle=1;fontColor=#D4A017;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="30" y="80" width="220" height="260" as="geometry"/></mxCell><mxCell id="4" value="Rules Engine&lt;br&gt;OPA / Rego&lt;br&gt;BRMS&lt;br&gt;Decision Table" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#D4A017;spacingTop=50;" vertex="1" parent="1"><mxGeometry x="30" y="80" width="220" height="160" as="geometry"/></mxCell><mxCell id="5" value="Bad spec produces:&lt;br&gt;&lt;b&gt;Consistent wrong decision&lt;br&gt;— every time, at scale&lt;/b&gt;" style="text;html=1;strokeColor=#C00000;fillColor=#FDDBD8;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#C00000;" vertex="1" parent="1"><mxGeometry x="40" y="280" width="200" height="50" as="geometry"/></mxCell><mxCell id="6" value="PROBABILISTIC SYSTEMS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7030A0;strokeColor=#FFFFFF;fontSize=13;fontStyle=1;fontColor=#FFFFFF;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="290" y="80" width="220" height="260" as="geometry"/></mxCell><mxCell id="7" value="LLM Agent&lt;br&gt;RAG Pipeline&lt;br&gt;AI Workflow&lt;br&gt;Agentic Orchestration" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#FFFFFF;spacingTop=50;" vertex="1" parent="1"><mxGeometry x="290" y="80" width="220" height="160" as="geometry"/></mxCell><mxCell id="8" value="Bad spec produces:&lt;br&gt;&lt;b&gt;Variable invisible failure&lt;br&gt;— hard to detect, hard to diagnose&lt;/b&gt;" style="text;html=1;strokeColor=#C00000;fillColor=#FDDBD8;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#C00000;" vertex="1" parent="1"><mxGeometry x="300" y="280" width="200" height="50" as="geometry"/></mxCell><mxCell id="9" value="HYBRID SYSTEMS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1C1C1C;strokeColor=#D4A017;fontSize=13;fontStyle=1;fontColor=#D4A017;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="550" y="80" width="220" height="260" as="geometry"/></mxCell><mxCell id="10" value="Deterministic layer&lt;br&gt;+ Probabilistic layer&lt;br&gt;(The enterprise AI stack)&lt;br&gt;Both combined" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#D4A017;spacingTop=50;" vertex="1" parent="1"><mxGeometry x="550" y="80" width="220" height="160" as="geometry"/></mxCell><mxCell id="11" value="Bad spec produces:&lt;br&gt;&lt;b&gt;Both failure modes simultaneously&lt;/b&gt;" style="text;html=1;strokeColor=#C00000;fillColor=#FDDBD8;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#C00000;" vertex="1" parent="1"><mxGeometry x="560" y="280" width="200" height="50" as="geometry"/></mxCell><mxCell id="12" value="The Specification Discipline governs all three equally.&lt;br&gt;The failure modes differ. The discipline is the same." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#1F3864;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="30" y="360" width="740" height="30" as="geometry"/></mxCell></root></mxGraphModel>