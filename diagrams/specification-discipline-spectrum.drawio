<mxGraphModel><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="The Specification Discipline Spectrum" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#1F3864;" vertex="1" parent="1"><mxGeometry x="30" y="20" width="740" height="40" as="geometry"/></mxCell><mxCell id="3" value="STATIC SPECIFICATION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDDBD8;strokeColor=#C00000;fontSize=14;fontStyle=1;fontColor=#C00000;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="30" y="80" width="350" height="200" as="geometry"/></mxCell><mxCell id="4" value="&lt;b&gt;Upfront&lt;/b&gt; — written before work begins&lt;br&gt;&lt;b&gt;Frozen&lt;/b&gt; — locked after sign-off&lt;br&gt;&lt;b&gt;Obsolete&lt;/b&gt; — diverges from the system as it evolves&lt;br&gt;&lt;b&gt;Waterfall-native&lt;/b&gt; — assumes complete knowledge upfront" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=40;" vertex="1" parent="1"><mxGeometry x="30" y="80" width="350" height="200" as="geometry"/></mxCell><mxCell id="5" value="LIVING SPECIFICATION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2EFDA;strokeColor=#375623;fontSize=14;fontStyle=1;fontColor=#375623;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="420" y="80" width="350" height="200" as="geometry"/></mxCell><mxCell id="6" value="&lt;b&gt;Incremental&lt;/b&gt; — written as understanding develops&lt;br&gt;&lt;b&gt;Versioned&lt;/b&gt; — evolves with the system&lt;br&gt;&lt;b&gt;Automated&lt;/b&gt; — validated by CI, not by intention&lt;br&gt;&lt;b&gt;Agile-compatible&lt;/b&gt; — precision without completeness upfront" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=40;" vertex="1" parent="1"><mxGeometry x="420" y="80" width="350" height="200" as="geometry"/></mxCell><mxCell id="7" value="The misconception lives here — both sides require rigour" style="text;html=1;strokeColor=#1F3864;fillColor=#DDEEFF;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=12;fontStyle=2;fontColor=#1F3864;" vertex="1" parent="1"><mxGeometry x="290" y="130" width="220" height="60" as="geometry"/></mxCell><mxCell id="8" value="" style="endArrow=none;startArrow=none;html=1;strokeColor=#1F3864;strokeWidth=2;dashed=1;" edge="1" parent="1"><mxGeometry x="400" y="80" width="10" height="200" relative="1" as="geometry"><Array as="points"><mxPoint x="400" y="80"/><mxPoint x="400" y="280"/></Array></mxGeometry></mxCell><mxCell id="9" value="IEEE 830&lt;br&gt;Big Design Upfront&lt;br&gt;Waterfall SRS" style="text;html=1;strokeColor=#C00000;fillColor=#FDDBD8;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#C00000;" vertex="1" parent="1"><mxGeometry x="60" y="310" width="140" height="60" as="geometry"/></mxCell><mxCell id="10" value="RFC 2119&lt;br&gt;BDD / Gherkin&lt;br&gt;Spec-by-Example" style="text;html=1;strokeColor=#375623;fillColor=#E2EFDA;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#375623;" vertex="1" parent="1"><mxGeometry x="460" y="310" width="140" height="60" as="geometry"/></mxCell><mxCell id="11" value="Specification by Example&lt;br&gt;Spec-Driven Development" style="text;html=1;strokeColor=#375623;fillColor=#E2EFDA;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontColor=#375623;" vertex="1" parent="1"><mxGeometry x="620" y="310" width="150" height="60" as="geometry"/></mxCell><mxCell id="12" value="⚠ The Agile reaction to waterfall was understandable — but &#xa;misread as &#39;no specification&#39;. Precision and agility coexist." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#666666;fontStyle=2;" ve