    <!-- Section 1: STRATEGIC GOALS (green) -->
    <mxCell id="sec_goals" value="1. STRATEGIC GOALS&#xa;Ranked organisational goals agents optimise toward · Priority order governs default trade-off resolution" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;fontColor=#1a4a1a;" vertex="1" parent="1">
      <mxGeometry x="50" y="102" width="480" height="55" as="geometry" />
    </mxCell>

    <!-- Section 2: TRADE-OFF HIERARCHIES (blue) -->
    <mxCell id="sec_tradeoff" value="2. TRADE-OFF HIERARCHIES&#xa;Explicit precedence rules for resolving goal conflicts · e.g. Security &gt; Compliance &gt; Speed &gt; Cost" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;fontColor=#1a3a5c;" vertex="1" parent="1">
      <mxGeometry x="50" y="159" width="480" height="55" as="geometry" />
    </mxCell>

    <!-- Section 3: OPERATIONAL CONSTRAINTS (red) -->
    <mxCell id="sec_constraints" value="3. OPERATIONAL CONSTRAINTS (HARD)&#xa;Non-negotiable boundaries · Violation triggers halt and escalation · Not subject to trade-off resolution" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;fontColor=#6b2020;" vertex="1" parent="1">
      <mxGeometry x="50" y="216" width="480" height="55" as="geometry" />
    </mxCell>

    <!-- Section 4: RISK APPETITE (orange) -->
    <mxCell id="sec_risk" value="4. RISK APPETITE&#xa;Tolerance levels by risk category — financial · reputational · security · operational · compliance" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;fontColor=#5a2800;" vertex="1" parent="1">
      <mxGeometry x="50" y="273" width="480" height="55" as="geometry" />
    </mxCell>

    <!-- Section 5: DECISION THRESHOLDS (yellow) -->
    <mxCell id="sec_thresholds" value="5. DECISION THRESHOLDS&#xa;Autonomous (agent alone) · Council deliberation · Human approval — defined by decision type and risk level" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;verticalAlign=middle;spacingLeft=10;fontColor=#5a4000;" vertex="1" parent="1">
      <mxGeometry x="50" y="330" width="480" height="55" as="geometry" />
    </mxCell>

    <!-- Section 6: GOVERNANCE (gray) -->
