      <mxGeometry x="50" y="387" width="480" height="52" as="geometry" />
    </mxCell>

    <!-- Anatomy footnote -->
    <mxCell id="a_footer" value="Consumed at every agent decision point. Not a prompt — a policy document. Changes require governed approval." style="text;html=1;strokeColor=#D0D0D0;fillColor=#F8F8F8;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=10;fontStyle=2;" vertex="1" parent="1">
      <mxGeometry x="50" y="451" width="480" height="30" as="geometry" />
    </mxCell>

    <!-- ===== MANIFEST LIFECYCLE ===== -->

    <!-- Step 1: AUTHOR (green - human) -->
    <mxCell id="lc1" value="1. AUTHOR&#xa;Human intent author encodes goals, trade-off hierarchies, constraints, and risk appetite in structured form" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontColor=#1a4a1a;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="580" y="72" width="530" height="60" as="geometry" />
    </mxCell>

    <!-- Step 2: VALIDATE (gray) -->
    <mxCell id="lc2" value="2. VALIDATE&#xa;Governance review — manifest reflects current strategy · trade-off rules are consistent · constraints are complete and unambiguous" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontColor=#333333;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="580" y="147" width="530" height="60" as="geometry" />
    </mxCell>

    <!-- Step 3: PUBLISH (blue) -->
    <mxCell id="lc3" value="3. PUBLISH&#xa;Manifest versioned and deployed to agent infrastructure · Prior version archived · All agents notified of new version" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontColor=#1a3a5c;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="580" y="222" width="530" height="60" as="geometry" />
    </mxCell>

    <!-- Step 4: CONSUME (dark - agent) -->
    <mxCell id="lc4" value="4. CONSUME&#xa;Agents reference manifest at each decision point · Outputs annotated with the manifest clause that authorised each decision" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#292929;strokeColor=#111111;fontColor=#FFFFFF;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="580" y="297" width="530" height="60" as="geometry" />
    </mxCell>

    <!-- Step 5: MONITOR (yellow) -->
    <mxCell id="lc5" value="5. MONITOR&#xa;System logs intent-alignment decisions and escalation patterns · Clause-level clusters signal ambiguity or drift" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#5a4000;fontSize=10;align=center;" vertex="1" parent="1">
      <mxGeometry x="580" y="372" width="530" height="60" as="geometry" />
